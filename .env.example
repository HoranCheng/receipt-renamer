# Receipt Renamer 环境变量
# 复制为 .env 并填入你的值

# Anthropic API Key（独立部署时需要）
# 在 artifact 环境中不需要，但独立部署时用户需要提供
# 方案A: 前端直接调用（仅限开发/个人使用，会暴露 key）
VITE_ANTHROPIC_API_KEY=

# 方案B: 通过代理服务器（推荐生产环境）
# VITE_AI_PROXY_URL=https://your-proxy.example.com/api/analyze

# Google OAuth Client ID（可选预置，用户也可在 UI 中输入）
VITE_GOOGLE_CLIENT_ID=
